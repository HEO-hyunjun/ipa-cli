{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "isolatedModules": true,
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"]
}
